<!-- src/templates/email-verification.hbs -->
<h2>Welcome to ComicNest, {{email}}!</h2>
<p>
  Thank you for registering on ComicNest — your ultimate platform for
  discovering and enjoying comics.
</p>
<p>
  Please click the button below to verify your email address and activate your
  account.
</p>
<a
  href='{{url}}'
  style='display: inline-block; padding: 10px 15px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 4px;'
>
  Verify Email
</a>
<p>If you didn't sign up for ComicNest, you can ignore this message.</p>